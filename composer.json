{
    "name": "boxed-code/laravel-challenge",
    "description": "Multi-method two factor authentication for Laravel apps.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Oliver Green",
            "email": "green2go@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=7.4",
        "illuminate/bus": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/events": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/notifications": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0",
        "mockery/mockery": "^1.0",
        "phpunit/phpunit": "^8.0|^9.0|^10.0|^11.0",
        "symfony/thanks": "^1.0",
        "laravel/ui": "^1.0|^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "BoxedCode\\Laravel\\Auth\\Challenge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BoxedCode\\Laravel\\Auth\\Challenge\\ChallengeServiceProvider"
            ]
        }
    },
    "suggest": {
        "pragmarx/google2fa": "Allows use of Google Authenticator (OTP)",
        "bacon/bacon-qr-code": "Allows local generation of QR code images",
        "laravel-notification-channels/twilio": "Allows the use of twilio SMS & voice"
    }
}
